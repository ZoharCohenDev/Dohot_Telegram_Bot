# Telegram Bot token from BotFather
BOT_TOKEN=

# Dohot backend base URL (no trailing slash)
DOHOT_API_URL=https://your-dohot-api.com

# Supabase project URL (no trailing slash)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key
SUPABASE_ANON_KEY=

# Admin credentials for Supabase Auth (email will be ADMIN_USERNAME@dohot.app)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Comma-separated list of authorized Telegram user IDs
# Use /myid in the bot to get your ID
ADMIN_TELEGRAM_IDS=123456789,987654321

# Enable daily admin notifications at 09:00 and 09:05 Asia/Jerusalem time
ENABLE_SCHEDULED_NOTIFICATIONS=false

# Google Sheets sync for newly created users
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_USERS_SHEET_NAME=Users
GOOGLE_SHEETS_FINANCE_SHEET_NAME=
ENABLE_GOOGLE_SHEETS_SYNC=false
